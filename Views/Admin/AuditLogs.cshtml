@model List<AppCompras.Models.Data.SystemLog>
@{
    ViewData["Title"] = "Logs de Auditoria - Fazenda Santa Fé";
    Layout = null; // Ou use seu layout padrão se preferir
}

<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"]</title>
    <link rel="icon" type="image/png" href="~/img/logo-40-anos.png" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/compras.css" />
    <style>
        .audit-container { padding: 20px; max-width: 1200px; margin: 0 auto; }
        .log-table { width: 100%; border-collapse: collapse; margin-top: 20px; background: #fff; box-shadow: 0 2px 5px rgba(0,0,0,0.1); }
        .log-table th, .log-table td { padding: 12px; text-align: left; border-bottom: 1px solid #eee; }
        .log-table th { background-color: #2c3e50; color: white; }
        .badge-action { padding: 4px 8px; border-radius: 4px; font-size: 0.85em; font-weight: bold; background: #e9ecef; }
        .timestamp { color: #666; font-size: 0.9em; }
        .btn-back { display: inline-block; margin-bottom: 20px; text-decoration: none; color: #3498db; font-weight: bold; }
    </style>
</head>
<body>
    <div class="audit-container">
        <header class="page-header">
            <div class="header-content">
                <div class="logo-section">
                    <img src="~/img/logo-40-anos.png" alt="Logo 40 anos Fazenda Santa Fé" class="logo-img-small" />
                    <div class="header-text">
                        <h1>LOGS DE AUDITORIA</h1>
                        <span class="subtitle">Administração do Sistema</span>
                    </div>
                </div>
                <div class="user-section">
                    <span class="welcome">Admin: @ViewBag.Username</span>
                    <a asp-action="Users" asp-controller="Admin" class="btn-logout">Usuários</a>
                    <a asp-action="Index" asp-controller="Compras" class="btn-logout">Voltar</a>
                </div>
            </div>
        </header>

        <div class="content-wrapper">
            <a href="@Url.Action("Index", "Compras")" class="btn-back">← Voltar para Consultas</a>
            
            <h2>Trilha de Auditoria (RF05)</h2>
            <p>Total de registros: @Model.Count</p>

            <table class="log-table">
                <thead>
                    <tr>
                        <th>Data/Hora</th>
                        <th>Usuário</th>
                        <th>Ação</th>
                        <th>Detalhes</th>
                        <th>Endereço IP</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var log in Model)
                    {
                        <tr>
                            <td class="timestamp">@log.CreatedAt.ToString("dd/MM/yyyy HH:mm:ss")</td>
                            <td><strong>@log.Username</strong> <br/><small>ID: @log.UserId</small></td>
                            <td><span class="badge-action">@log.Action</span></td>
                            <td>@log.Details</td>
                            <td>@(string.IsNullOrEmpty(log.IpAddress) ? "N/A" : log.IpAddress)</td>
                        </tr>
                    }
                    @if (Model.Count == 0)
                    {
                        <tr>
                            <td colspan="5" style="text-align:center;">Nenhum log registrado até o momento.</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</body>
</html>
