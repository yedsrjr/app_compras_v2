@model AppCompras.Models.ViewModels.ComprasViewModel
@using AppCompras.Models.Data
@using System.Text.Json
@{
    ViewData["Title"] = "Consulta de Compras";
    Layout = null;
}

<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"]</title>
    <link rel="icon" type="image/png" href="~/img/icone-logo-40-anos.png" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/compras.css" />
</head>
<body>
    <header class="page-header">
        <div class="header-content">
            <div class="logo-section">
                <img src="~/img/icone-logo-40-anos.png" alt="Logo 40 anos Fazenda Santa Fé" class="logo-img-small" />
                <div class="header-text">
                    <span class="subtitle">Sistema de Compras</span>
                </div>
            </div>
                <div class="user-section">
                    <div class="user-info">
                        <span class="welcome">Bem-vindo, @ViewBag.Username</span>
                        @if (ViewBag.UserRole != null)
                        {
                            <span class="role-badge">@ViewBag.UserRole</span>
                        }
                    </div>
                    @if (ViewBag.UserRole?.ToString() == UserRole.Administrador.ToString())
                    {
                        <a asp-action="Users" asp-controller="Admin" class="btn-logout">Usuários</a>
                    }
                    <a asp-action="ChangePassword" asp-controller="Login" class="btn-logout">Trocar senha</a>
                    <form asp-action="Logout" asp-controller="Login" method="post" style="display: inline;">
                        <button type="submit" class="btn-logout">Sair</button>
                    </form>
                </div>
        </div>
    </header>

    <div class="container">
        <div class="content-wrapper">
            <div class="page-title">
                <h2>Consulta de Itens de Compra</h2>
            </div>

            @if (TempData["ErrorMessage"] != null)
            {
                <div class="alert alert-error">
                    @TempData["ErrorMessage"]
                </div>
            }

            @if (TempData["SuccessMessage"] != null)
            {
                <div class="alert alert-success">
                    @TempData["SuccessMessage"]
                </div>
            }

            <!-- Formulário de Busca -->
            <div class="search-container">
                <form asp-action="Buscar" asp-controller="Compras" method="get" class="search-form">
                    <div class="search-row">
                        <div class="form-group-search">
                            <label for="tipoBusca">Tipo de Busca</label>
                            <select id="tipoBusca" name="tipoBusca" class="search-select" required>
                                <option value="">Selecione...</option>
                                <option value="pedido" selected="@(ViewBag.TipoBusca == "pedido" ? "selected" : null)">
                                    Código de Pedido de Compra
                                </option>
                                <option value="item" selected="@(ViewBag.TipoBusca == "item" ? "selected" : null)">
                                    Código de Item
                                </option>
                                <option value="descricao" selected="@(ViewBag.TipoBusca == "descricao" ? "selected" : null)">
                                    Descrição do Item
                                </option>
                            </select>
                        </div>

                        <div class="form-group-search">
                            <label for="valorBusca">Valor</label>
                            <input 
                                type="text" 
                                id="valorBusca" 
                                name="valorBusca" 
                                class="search-input" 
                                placeholder="Digite o código..."
                                value="@ViewBag.ValorBusca"
                                required />
                        </div>

                        <div class="form-group-search">
                            <label for="dataInicio">Data Inicial</label>
                            <input
                                type="date"
                                id="dataInicio"
                                name="dataInicio"
                                class="search-input"
                                value="@ViewBag.DataInicio" />
                        </div>

                        <div class="form-group-search">
                            <label for="dataFim">Data Final</label>
                            <input
                                type="date"
                                id="dataFim"
                                name="dataFim"
                                class="search-input"
                                value="@ViewBag.DataFim" />
                        </div>

                        <div class="form-group-search button-group">
                            <button type="submit" class="btn-search">
                                🔍 Buscar
                            </button>
                            <a asp-action="Index" class="btn-clear">
                                🔄 Limpar
                            </a>
                        </div>
                    </div>
                </form>
            </div>

            @if (Model.MenorValorItems.Count > 0)
            {
                <div class="results-info">
                    <p class="subtitle-info">Total de itens encontrados: @Model.MenorValorItems.Count</p>
                </div>

                <!-- Tabs Navigation -->
                <div class="tabs-container">
                    <button class="tab-button active" onclick="showTab('menor-valor')">
                        📊 Relatório
                    </button>
                    <button class="tab-button" onclick="showTab('dashboard')">
                        📈 Dashboard
                    </button>
                </div>

                <!-- Tab 1: Menor Valor -->
                <div id="tab-menor-valor" class="tab-content active">
                    <div class="table-controls">
                        <div class="page-size">
                            <label for="pageSizeSelect">Itens por página (Nº de itens)</label>
                            <select id="pageSizeSelect" class="search-select">
                                <option value="10" selected>10</option>
                                <option value="25">25</option>
                                <option value="50">50</option>
                                <option value="100">100</option>
                            </select>
                        </div>
                    </div>
                    <div class="table-container">
                        <table class="data-table">
                            <thead>
                                <tr>
                                    <th>Cód. PC</th>
                                    <th>Descrição</th>
                                    <th>Fornecedor</th>
                                    <th>Data</th>
                                    <th>Quantidade</th>
                                    <th>Preço Unitário</th>
                                    <th>Valor Total</th>
                                </tr>
                            </thead>
                            <tbody id="relatorioTableBody">
                                @foreach (var item in Model.MenorValorItems)
                                {
                                    <tr>
                                        <td>@item.CodPc</td>
                                        <td class="description">@item.Description</td>
                                        <td class="supplier">@(item.Fornecedor ?? "-")</td>
                                        <td class="text-center">@(item.DataPc?.ToString("dd/MM/yyyy") ?? "-")</td>
                                        <td class="text-right">@(item.Quantidade?.ToString("N2") ?? "-")</td>
                                        <td class="text-right price">@(item.PrecoUnitario?.ToString("C2") ?? "-")</td>
                                        <td class="text-right price-highlight">@(item.ValorTotalItem?.ToString("C2") ?? "-")</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                    <div class="pager footer">
                        <button type="button" id="prevPage" class="btn-clear">Anterior</button>
                        <span id="pageInfo" class="pager-info">Página 1 de 1</span>
                        <button type="button" id="nextPage" class="btn-search">Próxima</button>
                    </div>
                </div>

                <!-- Tab 2: Dashboard -->
                <div id="tab-dashboard" class="tab-content">
                    @{
                        var requiresItem = !string.Equals(ViewBag.TipoBusca as string, "item", StringComparison.OrdinalIgnoreCase);
                        var itemOptions = ViewBag.DashboardItemOptions as List<AppCompras.Models.ViewModels.ItemOptionViewModel>
                            ?? new List<AppCompras.Models.ViewModels.ItemOptionViewModel>();
                    }

                    <div class="dashboard-filters">
                        <label for="dashboardItemFilter">Item</label>
                        <select id="dashboardItemFilter" class="search-select">
                            <option value="">Selecione um item...</option>
                            @foreach (var item in itemOptions)
                            {
                                <option value="@item.Code" selected="@(requiresItem ? false : item.Code == (ViewBag.ValorBusca as string))">
                                    @item.Code — @item.Name
                                </option>
                            }
                        </select>
                    </div>

                    @if (requiresItem)
                    {
                        <div id="dashboardSelectHint" class="alert alert-error">
                            Selecione um item para carregar o dashboard completo.
                        </div>
                    }

                    <section id="analysisPanel" class="analysis-panel @(requiresItem ? "hidden" : "")">
                        <div class="analysis-header">
                            <div class="analysis-title">
                                <div class="analysis-item" id="analysisItemTitle">Item</div>
                                <div class="analysis-sub" id="analysisSubTitle">Fornecedor · Período</div>
                            </div>
                            <span class="analysis-badge" id="analysisCount">0 itens</span>
                        </div>

                        <div class="analysis-body">
                            <div class="metric-grid">
                                <div class="metric-card">
                                    <div class="metric-label">PREÇO MÉDIO</div>
                                    <div class="metric-value" id="metricAvg">R$ 0,00</div>
                                    <div class="metric-sub" id="metricAvgUnit">por unidade</div>
                                </div>
                                <div class="metric-card">
                                    <div class="metric-label">MENOR PREÇO</div>
                                    <div class="metric-value metric-green" id="metricMin">R$ 0,00</div>
                                    <div class="metric-sub" id="metricMinMeta">-</div>
                                </div>
                                <div class="metric-card">
                                    <div class="metric-label">MAIOR PREÇO</div>
                                    <div class="metric-value metric-red" id="metricMax">R$ 0,00</div>
                                    <div class="metric-sub" id="metricMaxMeta">-</div>
                                </div>
                                <div class="metric-card">
                                    <div class="metric-label">VARIAÇÃO</div>
                                    <div class="metric-value" id="metricVar">0,0%</div>
                                    <div class="metric-sub metric-red" id="metricVarMeta">mín → máx</div>
                                </div>
                            </div>

                            <div class="analysis-charts">
                                <div class="chart-card">
                                    <div class="chart-title">Evolução do preço unitário por compra</div>
                                    <div class="chart-canvas">
                                        <canvas id="lineChart"></canvas>
                                    </div>
                                    <div class="chart-legend" id="lineLegend"></div>
                                </div>

                                <div class="chart-card">
                                    <div class="chart-title">Média por fornecedor</div>
                                    <div class="chart-canvas">
                                        <canvas id="supplierBarChart"></canvas>
                                    </div>
                                    <div class="chart-legend" id="supplierLegend"></div>
                                </div>
                            </div>

                            <div class="analysis-table">
                                <div class="chart-title">Comparativo por pedido de compra</div>
                                <div class="table-controls">
                                    <div class="page-size">
                                        <label for="dashboardPageSizeSelect">Itens por página (Nº de itens)</label>
                                        <select id="dashboardPageSizeSelect" class="search-select">
                                            <option value="10" selected>10</option>
                                            <option value="25">25</option>
                                            <option value="50">50</option>
                                            <option value="100">100</option>
                                        </select>
                                    </div>
                                </div>
                                <div class="table-scroll">
                                    <table class="table-mini">
                                        <thead>
                                            <tr>
                                                <th>Cód. PC</th>
                                                <th>Data</th>
                                                <th>Fornecedor</th>
                                                <th>Qtd.</th>
                                                <th>Preço Unit.</th>
                                                <th>vs. Média</th>
                                                <th>Valor Total</th>
                                            </tr>
                                        </thead>
                                        <tbody id="analysisTableBody"></tbody>
                                    </table>
                                </div>
                                <div class="pager footer">
                                    <button type="button" id="dashboardPrevPage" class="btn-clear">Anterior</button>
                                    <span id="dashboardPageInfo" class="pager-info">Página 1 de 1</span>
                                    <button type="button" id="dashboardNextPage" class="btn-search">Próxima</button>
                                </div>
                            </div>
                        </div>
                    </section>

                    <script>
                        window.menorValorData = @Html.Raw(JsonSerializer.Serialize(Model.MenorValorItems));
                        window.analysisFilters = {
                            dataInicio: "@(ViewBag.DataInicio ?? "")",
                            dataFim: "@(ViewBag.DataFim ?? "")"
                        };
                        window.dashboardRequiresItem = @(requiresItem.ToString().ToLower());
                    </script>
                    <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.1/dist/chart.umd.min.js"></script>
                    <script src="~/js/compras-dashboard.js" asp-append-version="true"></script>
                </div>
            }
            else if (ViewBag.ValorBusca != null)
            {
                <div class="empty-state">
                    <div class="empty-icon">🔍</div>
                    <h3>Nenhum resultado encontrado</h3>
                    <p>Tente buscar com outros parâmetros</p>
                </div>
            }
            else
            {
                <div class="empty-state">
                    <div class="empty-icon">📋</div>
                    <h3>Realize uma busca</h3>
                    <p>Selecione o tipo de busca e informe o código para consultar</p>
                </div>
            }
        </div>
    </div>

    <script>
        function showTab(tabName) {
            document.querySelectorAll('.tab-content').forEach(tab => {
                tab.classList.remove('active');
            });
            
            document.querySelectorAll('.tab-button').forEach(btn => {
                btn.classList.remove('active');
            });
            
            document.getElementById('tab-' + tabName).classList.add('active');
            event.target.classList.add('active');
        }

        document.addEventListener('DOMContentLoaded', () => {
            const body = document.getElementById('relatorioTableBody');
            const pageSizeSelect = document.getElementById('pageSizeSelect');
            const prevPage = document.getElementById('prevPage');
            const nextPage = document.getElementById('nextPage');
            const pageInfo = document.getElementById('pageInfo');
            let currentPage = 1;

            const getRows = () => body ? Array.from(body.querySelectorAll('tr')) : [];
            const getPageSize = () => parseInt(pageSizeSelect?.value || '10', 10);

            const renderPage = () => {
                const rows = getRows();
                const pageSize = getPageSize();
                const totalPages = Math.max(1, Math.ceil(rows.length / pageSize));
                currentPage = Math.min(currentPage, totalPages);

                rows.forEach((row, index) => {
                    const start = (currentPage - 1) * pageSize;
                    const end = start + pageSize;
                    row.style.display = index >= start && index < end ? '' : 'none';
                });

                if (pageInfo) pageInfo.textContent = `Página ${currentPage} de ${totalPages}`;
                if (prevPage) prevPage.disabled = currentPage <= 1;
                if (nextPage) nextPage.disabled = currentPage >= totalPages;
            };

            if (pageSizeSelect) {
                pageSizeSelect.addEventListener('change', () => {
                    currentPage = 1;
                    renderPage();
                });
            }

            if (prevPage) {
                prevPage.addEventListener('click', () => {
                    currentPage = Math.max(1, currentPage - 1);
                    renderPage();
                });
            }

            if (nextPage) {
                nextPage.addEventListener('click', () => {
                    currentPage = currentPage + 1;
                    renderPage();
                });
            }

            renderPage();

            const params = new URLSearchParams(window.location.search);
            const tab = params.get('tab');
            if (tab && document.getElementById('tab-' + tab)) {
                const targetBtn = Array.from(document.querySelectorAll('.tab-button'))
                    .find(b => b.getAttribute('onclick')?.includes(`showTab('${tab}')`));
                if (targetBtn) {
                    targetBtn.click();
                } else {
                    showTab(tab);
                }
            }
        });
    </script>
</body>
</html>

