@model AppCompras.Models.ViewModels.ChangePasswordViewModel
@using AppCompras.Models.Data
@{
    ViewData["Title"] = "Alterar senha - Fazenda Santa Fé";
    Layout = null;
}

<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"]</title>
    <link rel="icon" type="image/png" href="~/img/icone-logo-40-anos.png" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/admin-user-form.css" />
</head>
<body>
    <header class="page-header">
        <div class="header-content">
            <div class="logo-section">
                <img src="~/img/icone-logo-40-anos.png" alt="Logo 40 anos Fazenda Santa Fé" class="logo-img-small" />
                <div class="header-text">
                    <span class="subtitle">Sistema de Compras</span>
                </div>
            </div>
            <div class="user-section">
                <div class="user-info">
                    <span class="welcome">Bem-vindo, <span>@ViewBag.Username</span></span>
                </div>
                @if (ViewBag.UserRole?.ToString() == UserRole.Administrador.ToString())
                {
                    <a asp-action="Users" asp-controller="Admin" class="header-btn">Usuários</a>
                }
                <a asp-action="Index" asp-controller="Compras" class="header-btn">Voltar</a>
            </div>
        </div>
    </header>

    <div class="page-shell">
        <div class="content">
            <div class="breadcrumb">
                <a asp-action="Index" asp-controller="Compras">Compras</a>
                <span class="breadcrumb-sep">›</span>
                <span>Alterar senha</span>
            </div>
            <div class="page-title">Alterar senha</div>

            <form asp-action="ChangePassword" asp-controller="Login" method="post">
                <div asp-validation-summary="ModelOnly" class="validation-summary"></div>

                <div class="card">
                    <div class="card-title">Segurança</div>
                    <div class="form-grid">
                        <div class="field span2">
                            <label>Senha atual <span class="req">*</span></label>
                            <div class="password-wrap">
                                <input type="password" asp-for="CurrentPassword" id="currentPassword" />
                                <button type="button" class="eye-btn" onclick="togglePass('currentPassword')">👁</button>
                            </div>
                            <span asp-validation-for="CurrentPassword" class="validation-message"></span>
                        </div>
                        <div class="field">
                            <label>Nova senha <span class="req">*</span></label>
                            <div class="password-wrap">
                                <input type="password" asp-for="NewPassword" id="newPassword" />
                                <button type="button" class="eye-btn" onclick="togglePass('newPassword')">👁</button>
                            </div>
                            <span asp-validation-for="NewPassword" class="validation-message"></span>
                        </div>
                        <div class="field">
                            <label>Confirmar nova senha <span class="req">*</span></label>
                            <div class="password-wrap">
                                <input type="password" asp-for="ConfirmPassword" id="confirmPassword" />
                                <button type="button" class="eye-btn" onclick="togglePass('confirmPassword')">👁</button>
                            </div>
                            <span asp-validation-for="ConfirmPassword" class="validation-message"></span>
                        </div>
                    </div>
                </div>

                <div class="footer-actions">
                    <a asp-action="Index" asp-controller="Compras" class="btn-cancel">Cancelar</a>
                    <button type="submit" class="btn-save">Salvar senha</button>
                </div>
            </form>
        </div>
    </div>

    <partial name="_ValidationScriptsPartial" />

    <script>
        function togglePass(id) {
            const inp = document.getElementById(id);
            inp.type = inp.type === 'password' ? 'text' : 'password';
        }
    </script>
</body>
</html>
